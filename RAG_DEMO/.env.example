# 复制为 .env 后填写。不要把真实 Key 提交到 git。

# ---------- 外网 Embedding / Chat（OpenAI 兼容）----------
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
# 通义等也可：OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
EMBEDDING_BATCH_SIZE=32

# ---------- Ubuntu Milvus（默认无密码，只填 host/port）----------
# 本机跑 compose：127.0.0.1
# Windows 连远程 Ubuntu：填局域网 IP，如 192.168.1.100
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_demo_chunks
MILVUS_METRIC=COSINE

# ---------- RAG 参数 ----------
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=4
# DATA_DIR=./data/sample
